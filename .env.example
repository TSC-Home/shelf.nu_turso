# =============================================================================
# Shelf.nu — SQLite/Turso fork
# Copy this file to .env and fill in your values.
# The .env file must live at the monorepo root (next to package.json).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Embedded SQLite — good for local dev and single-server Docker deployments.
DATABASE_URL="file:./dev.db"

# Turso cloud — use this instead of the file: URL when connecting to Turso.
# Leave DATABASE_AUTH_TOKEN empty when using a local file: database.
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# Random secret used to sign JWT access tokens and HMAC-sign local file URLs.
# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-use-a-random-32-byte-hex-string"

# Secret for invite link tokens.
# Generate with: openssl rand -hex 32
INVITE_TOKEN_SECRET="change-me-use-a-random-32-byte-hex-string"

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Public base URL of your instance (no trailing slash).
# Used in emails and QR code links.
SERVER_URL="http://localhost:3000"

APP_NAME="Shelf"

# Used for generating cuid with lowered chance of collision. Optional.
FINGERPRINT="a-custom-host-fingerprint"

# -----------------------------------------------------------------------------
# Email — relay.voidvalue.com
# -----------------------------------------------------------------------------

# API key from relay.voidvalue.com (used for transactional emails via HTTP API).
RELAY_API_KEY=""

# SMTP key from relay.voidvalue.com (used when sending via nodemailer/SMTP).
RELAY_SMTP_KEY=""

# Alternatively you can point at any SMTP relay:
# SMTP_HOST="relay.voidvalue.com"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PWD=""
SMTP_FROM="Shelf <noreply@example.com>"

# Set to false to skip sending the welcome/onboarding email on first sign-up.
SEND_ONBOARDING_EMAIL="false"

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# "local" — store files on the local filesystem (default, good for Docker).
# "s3"    — store files in any S3-compatible bucket (AWS S3, MinIO, R2, …).
STORAGE_DRIVER="local"

# Local storage: absolute path where uploaded files are written.
# Mount this as a Docker volume so files survive container restarts.
UPLOAD_DIR="/data/uploads"

# S3-compatible storage — only needed when STORAGE_DRIVER=s3.
# S3_ENDPOINT="https://s3.amazonaws.com"     # or https://minio.example.com:9000
# S3_BUCKET="my-shelf-bucket"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_REGION="us-east-1"
# S3_PUBLIC_URL="https://cdn.example.com"    # base URL for serving public files
# S3_FORCE_PATH_STYLE="false"                # set true for MinIO

# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------

# Set to false to make all premium features available without a subscription.
# This fork removes Stripe entirely — always keep this false.
ENABLE_PREMIUM_FEATURES="false"

# Set to true to prevent new users from self-registering.
# New accounts can still be created via invites.
DISABLE_SIGNUP="false"

# SSO is not supported in this fork.
DISABLE_SSO="true"

# -----------------------------------------------------------------------------
# Maps (optional)
# -----------------------------------------------------------------------------

MAPTILER_TOKEN=""
GEOCODING_USER_AGENT="Shelf self-hosted (https://example.com)"

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------

# Email address that receives account-deletion requests.
ADMIN_EMAIL="admin@example.com"

# Email address for internal support links shown to users.
SUPPORT_EMAIL="support@example.com"

# -----------------------------------------------------------------------------
# Analytics / monitoring (all optional — leave blank to disable)
# -----------------------------------------------------------------------------

MICROSOFT_CLARITY_ID=""
CLOUDFLARE_WEB_ANALYTICS_TOKEN=""

# Sentry error tracking
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# -----------------------------------------------------------------------------
# Calendar (optional)
# -----------------------------------------------------------------------------

# FullCalendar license key — required only for the resource timeline view.
FULL_CALENDAR_LICENSE_KEY=""

# -----------------------------------------------------------------------------
# QR code URL shortener (optional)
# -----------------------------------------------------------------------------

# If set, QR codes use shortened URLs. Must not include protocol or trailing slash.
# URL_SHORTENER="eam.sh"
