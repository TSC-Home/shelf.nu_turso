{
  "name": "@shelf/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:prepare-migration": "tsx src/prepare-migration.ts",
    "db:deploy-migration": "tsx src/migrate.ts && prisma generate",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@prisma/adapter-libsql": "^6.19.3",
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@shelf/typescript-config": "workspace:*",
    "@types/node": "^22.19.17",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
